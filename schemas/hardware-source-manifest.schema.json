{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://devicecheck.local/schemas/hardware-source-manifest.schema.json",
  "title": "DeviceCheck Hardware Source Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "sourceId",
    "name",
    "kind",
    "trustTier",
    "retrievedAt",
    "license",
    "artifacts"
  ],
  "properties": {
    "sourceId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "enum": [
        "raw-local",
        "public-id-database",
        "os-driver-store",
        "open-source-profile",
        "oem-spec",
        "user-attestation",
        "generated-cache"
      ]
    },
    "trustTier": {
      "type": "string",
      "enum": [
        "raw",
        "high",
        "medium-high",
        "medium",
        "low",
        "advisory"
      ]
    },
    "url": {
      "type": "string"
    },
    "localPath": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "commit": {
      "type": "string"
    },
    "retrievedAt": {
      "type": "string",
      "format": "date-time"
    },
    "license": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "string"
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "sha256"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[A-Fa-f0-9]{64}$"
          },
          "sizeBytes": {
            "type": "integer",
            "minimum": 0
          },
          "generatedBy": {
            "type": "string"
          }
        }
      }
    }
  }
}
